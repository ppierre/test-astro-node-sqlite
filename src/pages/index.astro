---
import Layout from "../layouts/Layout.astro";
import { allUser } from "../db";

const users = allUser();
---

<Layout>
  <h1>No Drizzle :-)</h1>
  <ul>
    {
      users.map((user) => (
        <li>
          <a href={`/users/${user.id}`}>
            <h2>{user.name}</h2>
            <p>{user.email}</p>
          </a>
        </li>
      ))
    }
  </ul>
  <a href="/users/edit/">Add new user</a>
</Layout>
