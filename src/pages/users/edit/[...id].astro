---
import { insertUser, updateUser, getUserById } from "../../../db";
import type { User } from "../../../db/schema";
import Layout from "../../../layouts/Layout.astro";
export const prerender = false;

let id = Astro.params.id ? Number(Astro.params.id) : null;
const user = id ? getUserById(id) : null;

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const name = formData.get("name") as string;
  const age = parseInt(formData.get("age") as string);
  const email = formData.get("email") as string;
  if (id) {
    updateUser({ id, name, age, email });
  } else {
    id = insertUser({ name, age, email });
  }
  return Astro.redirect(`/users/${id}`);
}
---

<Layout>
  {user?.id ? <h1>Edit User ID: {id}</h1> : <h1>Create User</h1>}
  <form method="POST">
    <label for="name">Name:</label>
    <input type="text" id="name" name="name" required value={user?.name} />

    <label for="age">Age:</label>
    <input type="number" id="age" name="age" required value={user?.age} />

    <label for="email">Email:</label>
    <input type="email" id="email" name="email" required value={user?.email} />

    {
      user?.id ? (
        <button type="submit">Save</button>
      ) : (
        <button type="submit">Create</button>
      )
    }
  </form>
</Layout>
